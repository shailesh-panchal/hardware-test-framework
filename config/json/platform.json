{
    "schema_version": 1,
    "platform": {
        "name": "rk3588_evb",
        "vendor": "rockchip",
        "soc": "rk3588",
        "description": "RK3588 Evaluation Board"
    },

    "bindings": [
        {
            "device": "status_led",
            "plugin": "gpio_linux",
            "interface": "gpio",
            "enable" : true,

            "configuration": {
                "chip": "gpiochip0",
                "line": 24,
                "active_low": false
            }
        },

        {
            "device": "user_button",
            "plugin": "gpio_linux",
            "interface": "gpio",
            "enable" : true,

            "configuration": {
                "chip": "gpiochip0",
                "line": 26,
                "active_low": true
            }
        },

        {
            "device": "ambient_temperature",
            "plugin": "i2c_linux",
            "interface": "i2c",
            "enable" : true,
            "compatible": "tmp102",

            "configuration": {
                "bus": "/dev/i2c-1",
                "address": 72,
                "frequency_hz": 100000
            }
        },

        {
            "device": "motion_sensor",
            "plugin": "i2c_linux",
            "interface": "i2c",
            "enable" : true,
            "compatible": "mpu6050",

            "configuration": {
                "bus": "/dev/i2c-1",
                "address": 104,
                "frequency_hz": 100000
            }
        },

        {
            "device": "main_camera",
            "plugin": "camera_v4l2",
            "interface": "v4l2",
            "enable" : true,
            "compatible": "ov5640",

            "configuration": {
                "device": "/dev/video0",
                "pixel_format": "YUYV",
                "resolution": "1920x1080"
            }
        }
    ]
}